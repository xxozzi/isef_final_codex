\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of D-COLA. Dense checkpoints from one training trajectory are scored by per-domain validation loss, anchored at the checkpoint minimizing worst-domain risk, filtered by a low interpolation barrier, and reweighted by a convex objective over cached predictions. The output remains a single model, not an ensemble.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:overview}{{1}{2}{Overview of D-COLA. Dense checkpoints from one training trajectory are scored by per-domain validation loss, anchored at the checkpoint minimizing worst-domain risk, filtered by a low interpolation barrier, and reweighted by a convex objective over cached predictions. The output remains a single model, not an ensemble}{figure.1}{}}
