\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {What the covariance term is measuring.} Each checkpoint induces a samplewise validation-loss profile inside each source domain. When two checkpoints fail on the same hidden slice, their centered profiles are aligned and the conflict penalty stays large. When they cover different slices, their profiles are complementary and the weighted variance term drops.}}{9}{figure.caption.11}\protected@file@percent }
\newlabel{fig:hidden_shift}{{4}{9}{\textbf {What the covariance term is measuring.} Each checkpoint induces a samplewise validation-loss profile inside each source domain. When two checkpoints fail on the same hidden slice, their centered profiles are aligned and the conflict penalty stays large. When they cover different slices, their profiles are complementary and the weighted variance term drops}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Why noncontiguity can matter.} Contiguous windows are a time-based proxy. The mergeable-complementarity view says the actual object is error-structure coverage inside a mergeable region, so the best checkpoints need not be adjacent along training time.}}{9}{figure.caption.12}\protected@file@percent }
\newlabel{fig:noncontiguity}{{5}{9}{\textbf {Why noncontiguity can matter.} Contiguous windows are a time-based proxy. The mergeable-complementarity view says the actual object is error-structure coverage inside a mergeable region, so the best checkpoints need not be adjacent along training time}{figure.caption.12}{}}
