\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Corner-view 3D intuition.} The final object is one single soup inside a connected valley. Barrier filtering enforces mergeability, the covariance term prefers checkpoints that cancel different failure directions, and the final soup lies inside the compatible region instead of averaging blindly across the bank.}}{10}{figure.caption.13}\protected@file@percent }
\newlabel{fig:3d}{{6}{10}{\textbf {Corner-view 3D intuition.} The final object is one single soup inside a connected valley. Barrier filtering enforces mergeability, the covariance term prefers checkpoints that cancel different failure directions, and the final soup lies inside the compatible region instead of averaging blindly across the bank}{figure.caption.13}{}}
