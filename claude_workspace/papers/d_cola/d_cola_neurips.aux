\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Detailed visual methodology for D-COLA. The method first computes per-domain validation losses and selects the checkpoint minimizing worst-domain loss, then filters checkpoints by interpolation barriers, estimates redundancy through a covariance proxy on cached losses, and finally solves a simplex optimization to produce one weight soup. This figure is schematic but calculation-faithful: each panel corresponds directly to a quantity in Eqs.~\eqref  {eq:anchor}--\eqref  {eq:objective}.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:methodology}{{2}{4}{Detailed visual methodology for D-COLA. The method first computes per-domain validation losses and selects the checkpoint minimizing worst-domain loss, then filters checkpoints by interpolation barriers, estimates redundancy through a covariance proxy on cached losses, and finally solves a simplex optimization to produce one weight soup. This figure is schematic but calculation-faithful: each panel corresponds directly to a quantity in Eqs.~\eqref {eq:anchor}--\eqref {eq:objective}}{figure.2}{}}
