\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Why exact weights can matter less than finding the right face.} Once the selected checkpoints lie on a low-curvature, low-conflict face of the simplex, a large region of weights can have nearly identical objective value. This is why support discovery can matter more than precise coefficient tuning.}}{11}{figure.caption.14}\protected@file@percent }
\newlabel{fig:simplex}{{7}{11}{\textbf {Why exact weights can matter less than finding the right face.} Once the selected checkpoints lie on a low-curvature, low-conflict face of the simplex, a large region of weights can have nearly identical objective value. This is why support discovery can matter more than precise coefficient tuning}{figure.caption.14}{}}
