\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces What D-COLA is computing at each step. Left: the anchor is chosen by minimizing the maximum source-domain validation loss across checkpoints. Right: candidates are screened by interpolation barriers, redundant checkpoints are exposed by the covariance matrix, and the final simplex weights concentrate on low-barrier, nonredundant checkpoints. All panels are schematic and meant to build intuition, not to report experimental results.}}{6}{figure.3}\protected@file@percent }
\newlabel{fig:selection}{{3}{6}{What D-COLA is computing at each step. Left: the anchor is chosen by minimizing the maximum source-domain validation loss across checkpoints. Right: candidates are screened by interpolation barriers, redundant checkpoints are exposed by the covariance matrix, and the final simplex weights concentrate on low-barrier, nonredundant checkpoints. All panels are schematic and meant to build intuition, not to report experimental results}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces SWAD versus D-COLA. SWAD uniformly averages a contiguous interval. D-COLA reweights a filtered candidate set around a worst-domain anchor; weights need not be uniform and support need not be contiguous in time.}}{6}{figure.4}\protected@file@percent }
\newlabel{fig:timeline}{{4}{6}{SWAD versus D-COLA. SWAD uniformly averages a contiguous interval. D-COLA reweights a filtered candidate set around a worst-domain anchor; weights need not be uniform and support need not be contiguous in time}{figure.4}{}}
