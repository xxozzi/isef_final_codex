\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Illustrative trade-off between covariance reduction and locality. Driving covariance too low can force weights toward distant checkpoints; D-COLA seeks a point on the low-covariance, low-barrier frontier instead of optimizing either objective in isolation.}}{18}{figure.9}\protected@file@percent }
\newlabel{fig:tradeoff}{{9}{18}{Illustrative trade-off between covariance reduction and locality. Driving covariance too low can force weights toward distant checkpoints; D-COLA seeks a point on the low-covariance, low-barrier frontier instead of optimizing either objective in isolation}{figure.9}{}}
