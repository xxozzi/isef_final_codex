\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {\textup  {\textsc  {CORA}}{} overview.} Starting from one dense trajectory, \textup  {\textsc  {CORA}}{} constructs a connected near-optimal checkpoint set, computes a predictive barycenter over that set, estimates examplewise multiplicity to define a consensus core and disagreement fringe, and solves a convex post-hoc simplex problem whose output is a single weight soup.}}{3}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:overview}{{1}{3}{\textbf {\cora {} overview.} Starting from one dense trajectory, \cora {} constructs a connected near-optimal checkpoint set, computes a predictive barycenter over that set, estimates examplewise multiplicity to define a consensus core and disagreement fringe, and solves a convex post-hoc simplex problem whose output is a single weight soup}{figure.caption.2}{}}
