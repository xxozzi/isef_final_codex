\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Prediction-space geometry.} For a fixed example, candidate checkpoint predictions can disagree substantially while remaining equally low-loss globally. \textup  {\textsc  {CORA}}{} targets the barycenter on low-multiplicity examples and avoids brittle fringe commitments.}}{10}{figure.caption.12}\protected@file@percent }
\newlabel{fig:geometry}{{4}{10}{\textbf {Prediction-space geometry.} For a fixed example, candidate checkpoint predictions can disagree substantially while remaining equally low-loss globally. \cora {} targets the barycenter on low-multiplicity examples and avoids brittle fringe commitments}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Core matching versus fringe hedging.} The \textup  {\textsc  {CORA}}{} objective emphasizes barycenter matching where multiplicity is low and worst-case caution where multiplicity is high. This differs structurally from both flatness-only and drift-only selectors.}}{10}{figure.caption.13}\protected@file@percent }
\newlabel{fig:objective}{{5}{10}{\textbf {Core matching versus fringe hedging.} The \cora {} objective emphasizes barycenter matching where multiplicity is low and worst-case caution where multiplicity is high. This differs structurally from both flatness-only and drift-only selectors}{figure.caption.13}{}}
