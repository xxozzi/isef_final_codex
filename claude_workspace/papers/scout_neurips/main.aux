\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Diminishing returns and redundancy.} The \textup  {\textsc  {SCOUT}}{} coverage utility rewards unique help on hard examples, but the gain decays as those examples become covered. The second-order term behaves like a redundancy penalty, which is why covariance-aware heuristics can work even though they are not direct optimizers of the exact robust objective.}}{10}{figure.caption.15}\protected@file@percent }
\newlabel{fig:diminishing}{{5}{10}{\textbf {Diminishing returns and redundancy.} The \scout {} coverage utility rewards unique help on hard examples, but the gain decays as those examples become covered. The second-order term behaves like a redundancy penalty, which is why covariance-aware heuristics can work even though they are not direct optimizers of the exact robust objective}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Toy separation intuition.} If early checkpoints cover one hard subset and late checkpoints cover another, the best robust soup can be noncontiguous even when all candidate checkpoints are individually soup-safe. This is the structural regime where \textup  {\textsc  {SCOUT}}{} can beat interval-only post-hoc selectors.}}{10}{figure.caption.16}\protected@file@percent }
\newlabel{fig:toy}{{6}{10}{\textbf {Toy separation intuition.} If early checkpoints cover one hard subset and late checkpoints cover another, the best robust soup can be noncontiguous even when all candidate checkpoints are individually soup-safe. This is the structural regime where \scout {} can beat interval-only post-hoc selectors}{figure.caption.16}{}}
