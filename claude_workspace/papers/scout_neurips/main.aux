\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {\textup  {\textsc  {SCOUT}}{} overview.} A dense trajectory is reduced to a low-loss barrier-filtered candidate pool. \textup  {\textsc  {SCOUT}}{} then directly optimizes robust example coverage over the convex hull of uniform \(M\)-checkpoint soups and deploys a single weighted soup. The paper's main point is that the optimized post-hoc objective is the same object that appears in the target-risk certificate.}}{3}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:overview}{{1}{3}{\textbf {\scout {} overview.} A dense trajectory is reduced to a low-loss barrier-filtered candidate pool. \scout {} then directly optimizes robust example coverage over the convex hull of uniform \(M\)-checkpoint soups and deploys a single weighted soup. The paper's main point is that the optimized post-hoc objective is the same object that appears in the target-risk certificate}{figure.caption.2}{}}
