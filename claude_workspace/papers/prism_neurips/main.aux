\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {\textup  {\textsc  {PRISM}}{} overview.} A dense single-run trajectory is reduced to a low-loss, anchor-screened candidate pool. The action space consists of uniform soups over feasible subsets of that pool. \textup  {\textsc  {PRISM}}{} then chooses the soup with smallest worst-case regret to the best feasible soup over hidden source-supported subpopulations of the pooled support split.}}{2}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:overview}{{1}{2}{\textbf {\prism {} overview.} A dense single-run trajectory is reduced to a low-loss, anchor-screened candidate pool. The action space consists of uniform soups over feasible subsets of that pool. \prism {} then chooses the soup with smallest worst-case regret to the best feasible soup over hidden source-supported subpopulations of the pooled support split}{figure.caption.2}{}}
