\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {How one objective explains two empirical stories.} Left: as temperature changes, the same adaptation-information functional moves from a broad variance-sensitive regime to a sharp support-coverage regime. Right: under a quadratic local model, flatness appears as the low-adaptation-information limit because variance across the bank is controlled by Hessian--covariance interactions.}}{8}{figure.caption.7}\protected@file@percent }
\newlabel{fig:regimes-quad}{{3}{8}{\textbf {How one objective explains two empirical stories.} Left: as temperature changes, the same adaptation-information functional moves from a broad variance-sensitive regime to a sharp support-coverage regime. Right: under a quadratic local model, flatness appears as the low-adaptation-information limit because variance across the bank is controlled by Hessian--covariance interactions}{figure.caption.7}{}}
