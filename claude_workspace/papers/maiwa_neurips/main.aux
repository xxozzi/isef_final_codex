\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Geometric intuition.} Left: the shared posterior $w$ lives in the full-bank simplex, and each source domain induces a Gibbs-specialized tilt $q_i^w$ toward its preferred checkpoints. Right: on a 3-checkpoint slice, the \textup  {\textsc  {MAIWA}}{} objective trades pooled risk against specialization cost. The method acts on the full simplex directly; there is no separate screening or feasible-set construction.}}{5}{figure.caption.6}\protected@file@percent }
\newlabel{fig:simplex}{{2}{5}{\textbf {Geometric intuition.} Left: the shared posterior $w$ lives in the full-bank simplex, and each source domain induces a Gibbs-specialized tilt $q_i^w$ toward its preferred checkpoints. Right: on a 3-checkpoint slice, the \maiwa {} objective trades pooled risk against specialization cost. The method acts on the full simplex directly; there is no separate screening or feasible-set construction}{figure.caption.6}{}}
