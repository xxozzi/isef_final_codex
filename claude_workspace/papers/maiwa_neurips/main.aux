\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {\textup  {\textsc  {MAIWA}}{} end-to-end on the full checkpoint bank.} The method starts from the entire bank, computes per-domain held-out losses on every checkpoint, forms Gibbs-specialized posteriors for each domain, and optimizes one global bank posterior $w$ by minimizing pooled risk plus average adaptation information. There is no preselection stage.}}{3}{figure.caption.4}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:pipeline}{{1}{3}{\textbf {\maiwa {} end-to-end on the full checkpoint bank.} The method starts from the entire bank, computes per-domain held-out losses on every checkpoint, forms Gibbs-specialized posteriors for each domain, and optimizes one global bank posterior $w$ by minimizing pooled risk plus average adaptation information. There is no preselection stage}{figure.caption.4}{}}
