\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Low-temperature complementarity.} Each column is a checkpoint, each row is a source domain, and darker cells indicate lower domain loss. When different domains prefer different checkpoints, the adaptation-information term becomes a code-length penalty for missing those checkpoints. The full-bank posterior therefore spreads mass across complementary atoms instead of collapsing to a single point.}}{10}{figure.caption.8}\protected@file@percent }
\newlabel{fig:coverage}{{4}{10}{\textbf {Low-temperature complementarity.} Each column is a checkpoint, each row is a source domain, and darker cells indicate lower domain loss. When different domains prefer different checkpoints, the adaptation-information term becomes a code-length penalty for missing those checkpoints. The full-bank posterior therefore spreads mass across complementary atoms instead of collapsing to a single point}{figure.caption.8}{}}
