\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Why reweighting induces a fragility operator.} Nearby target domains are modeled as local redistributions of source-support mass. Examplewise slope vectors that fan out strongly under these redistributions produce a large covariance \(B\), so directions aligned with them are shrunk more aggressively by \textup  {\textsc  {SWING}}{}.}}{8}{figure.caption.11}\protected@file@percent }
\newlabel{fig:simplex}{{3}{8}{\textbf {Why reweighting induces a fragility operator.} Nearby target domains are modeled as local redistributions of source-support mass. Examplewise slope vectors that fan out strongly under these redistributions produce a large covariance \(B\), so directions aligned with them are shrunk more aggressively by \swing {}}{figure.caption.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Why anisotropy matters}{8}{subsection.5.4}\protected@file@percent }
\newlabel{thm:scalar_gap}{{1}{8}{Comparison to scalar shrinkage}{proposition.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Two-dimensional analogue of Proposition~\ref {thm:scalar_gap}.} The fit solution \(z_{\mathrm  {fit}}\) lies away from the basin center \(\mu \). The best scalar shrinkage moves only along the dashed ray. The \textup  {\textsc  {SWING}}{} optimum follows the anisotropic geometry defined by \(A\) and \(B\), producing a lower robust surrogate value whenever fragility is direction-dependent.}}{9}{figure.caption.12}\protected@file@percent }
\newlabel{fig:2d}{{4}{9}{\textbf {Two-dimensional analogue of Proposition~\ref {thm:scalar_gap}.} The fit solution \(z_{\mathrm {fit}}\) lies away from the basin center \(\mu \). The best scalar shrinkage moves only along the dashed ray. The \swing {} optimum follows the anisotropic geometry defined by \(A\) and \(B\), producing a lower robust surrogate value whenever fragility is direction-dependent}{figure.caption.12}{}}
