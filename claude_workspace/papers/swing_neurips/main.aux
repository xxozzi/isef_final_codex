\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Three-dimensional intuition for \textup  {\textsc  {SWING}}{}.} Left: dense checkpoints define a connected low-loss basin and a center \(\mu \). Middle: the basin subspace supplies the coordinates in which the local fit, isotropic inflation, and fragility are estimated. Right: \textup  {\textsc  {SWING}}{} contracts the inflated baseline anisotropically, suppressing high-fragility directions more than low-fragility directions.}}{7}{figure.caption.11}\protected@file@percent }
\newlabel{fig:basin3d}{{2}{7}{\textbf {Three-dimensional intuition for \swing {}.} Left: dense checkpoints define a connected low-loss basin and a center \(\mu \). Middle: the basin subspace supplies the coordinates in which the local fit, isotropic inflation, and fragility are estimated. Right: \swing {} contracts the inflated baseline anisotropically, suppressing high-fragility directions more than low-fragility directions}{figure.caption.11}{}}
