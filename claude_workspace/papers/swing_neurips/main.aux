\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Why reweighting induces a fragility operator.} Nearby target domains are modeled as local redistributions of source-support mass. Examplewise slope vectors that fan out strongly under these redistributions produce a large covariance \(B\), so directions aligned with them are shrunk more aggressively by \textup  {\textsc  {SWING}}{}.}}{11}{figure.caption.12}\protected@file@percent }
\newlabel{fig:simplex}{{3}{11}{\textbf {Why reweighting induces a fragility operator.} Nearby target domains are modeled as local redistributions of source-support mass. Examplewise slope vectors that fan out strongly under these redistributions produce a large covariance \(B\), so directions aligned with them are shrunk more aggressively by \swing {}}{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.6}Certificate improvement, estimation, and stability}{11}{subsection.5.6}\protected@file@percent }
\newlabel{prop:gain}{{3}{11}{Exact certificate gain over the inflated baseline}{proposition.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Two-dimensional analogue of Proposition~\ref {prop:scalar_gap}.} The inflated baseline \(z_\tau \) lies away from the basin center \(\mu \). The best scalar shrinkage moves only along the dashed ray. The \textup  {\textsc  {SWING}}{} optimum follows the anisotropic geometry defined by \(A_\tau \) and \(B\), producing a lower robust surrogate value whenever fragility is direction-dependent.}}{12}{figure.caption.13}\protected@file@percent }
\newlabel{fig:2d}{{4}{12}{\textbf {Two-dimensional analogue of Proposition~\ref {prop:scalar_gap}.} The inflated baseline \(z_\tau \) lies away from the basin center \(\mu \). The best scalar shrinkage moves only along the dashed ray. The \swing {} optimum follows the anisotropic geometry defined by \(A_\tau \) and \(B\), producing a lower robust surrogate value whenever fragility is direction-dependent}{figure.caption.13}{}}
