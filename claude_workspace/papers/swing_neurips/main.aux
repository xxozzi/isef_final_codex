\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {\textup  {\textsc  {SWING}}{} pipeline.} A dense checkpoint bank is reduced to a connected safe pool. That pool defines a basin center \(\mu \) and a low-rank subspace \(U\). On disjoint source splits, \textup  {\textsc  {SWING}}{} estimates a source-fit operator \(\hat  A\) and a reweighting fragility operator \(\hat  B\), then outputs one deployable model by minimizing the surrogate within the basin trust region; when the constraint is inactive, this reduces to generalized eigen-shrinkage.}}{3}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:overview}{{1}{3}{\textbf {\swing {} pipeline.} A dense checkpoint bank is reduced to a connected safe pool. That pool defines a basin center \(\mu \) and a low-rank subspace \(U\). On disjoint source splits, \swing {} estimates a source-fit operator \(\hat A\) and a reweighting fragility operator \(\hat B\), then outputs one deployable model by minimizing the surrogate within the basin trust region; when the constraint is inactive, this reduces to generalized eigen-shrinkage}{figure.caption.2}{}}
