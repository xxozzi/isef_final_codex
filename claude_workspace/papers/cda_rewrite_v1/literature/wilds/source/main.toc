\contentsline {subsection}{\numberline {5.2}Types of in-distribution settings}{18}{subsection.5.2}
\contentsline {paragraph}{Test-to-test (train on $P^\mathsf {test}$, test on $P^\mathsf {test}$).}{18}{subsection.5.2}
\contentsline {paragraph}{Mixed-to-test (train on a mixture of $P^\mathsf {train}$ and $P^\mathsf {test}$, test on $P^\mathsf {test}$).}{18}{subsection.5.2}
\contentsline {paragraph}{Train-to-train (train on $P^\mathsf {train}$, evaluate on $P^\mathsf {train}$).}{18}{subsection.5.2}
\contentsline {paragraph}{Average (report average instead of worst-case performance).}{19}{subsection.5.2}
\contentsline {paragraph}{Random split (train and evaluate on an i.i.d.\nobreakspace {}split).}{19}{subsection.5.2}
